# Copy to .env and adjust as needed.
# Vertex managed tuning base model (console / vertexai.tuning.sft)
# VERTEX_BASE_MODEL=Qwen/Qwen3.5-4B
# Hugging Face equivalent of the Vertex base model above
# HF_MODEL_ID=Qwen/Qwen3.5-4B
# Local inference model
# MLX_MODEL_ID=Qwen/Qwen3.5-4B
# MLX_SERVER_HOST=127.0.0.1
# MLX_SERVER_PORT=8080
# Qwen thinking mode (reason before tool calls / replies)
# ENABLE_THINKING=true
# Agent generation budget per step (thinking + output)
# AGENT_MAX_TOKENS=4096
