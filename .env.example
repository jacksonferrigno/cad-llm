# Copy to .env and adjust as needed.
# Vertex managed tuning base model (console / vertexai.tuning.sft)
# VERTEX_BASE_MODEL=qwen/qwen3@qwen3-4b
# Hugging Face equivalent of the Vertex base model above
# HF_MODEL_ID=Qwen/Qwen3-4B
# Local MLX inference — 4-bit conversion of Qwen/Qwen3-4B
# MLX_MODEL_ID=mlx-community/Qwen3-4B-4bit
# MLX_SERVER_HOST=127.0.0.1
# MLX_SERVER_PORT=8080
